# ─────────────────────────────────────────────────────────────
#  Conecta Imperatriz — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha com seus valores reais
# ─────────────────────────────────────────────────────────────

# ► Aplicação
APP_NAME="Conecta Imperatriz API"
APP_ENV=development          # development | staging | production
APP_DEBUG=True
APP_VERSION=1.0.0

# ► Servidor
HOST=0.0.0.0
PORT=8000

# ► Banco de Dados PostgreSQL
DATABASE_URL=postgresql://postgres:senha_aqui@localhost:5432/conecta_imperatriz

# ► Segurança JWT
JWT_SECRET_KEY=troque-esta-chave-por-uma-bem-grande-e-aleatoria-em-producao
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440    # 24 horas

# ► CORS — origens permitidas (separar por vírgula). "null" permite abrir o painel direto do arquivo
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:5500,null

# ► Storage de Fotos
# Modo: 'local' (dev) ou 'supabase' (produção)
STORAGE_MODE=local

# ► Storage local (modo 'local')
UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=http://localhost:8000

# ► Supabase Storage (modo 'supabase')
# Pegar em: https://supabase.com/dashboard/project/_/settings/api
# SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_KEY=eyJhbGc...      # service_role key (NÃO a anon!)
# SUPABASE_BUCKET=conecta-imperatriz-fotos

# ► Limites de upload
MAX_UPLOAD_SIZE_MB=10
IMAGEM_MAX_LARGURA=1920        # px — fotos grandes são redimensionadas
IMAGEM_QUALIDADE=85            # 1-100 — qualidade JPEG após compressão
THUMBNAIL_LARGURA=400          # px — thumbnail para listagens

# ► E-mail (para recuperação de senha — configurar depois)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=naoresponda@imperatriz.ma.gov.br
# SMTP_PASSWORD=senha_app
